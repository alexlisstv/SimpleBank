# Copy to .env and adjust. django-environ reads this from the project root.

SECRET_KEY=your-secret-key-here
DEBUG=True

# Comma-separated hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — same credentials as docker-compose `db` service
POSTGRES_USER=simplebank
POSTGRES_PASSWORD=simplebank
POSTGRES_DB=simplebank

# App connection string (host 127.0.0.1 when DB port 5432 is published to the host)
DATABASE_URL=postgres://simplebank:simplebank@127.0.0.1:5432/simplebank

# Optional: set True in dev when the app runs in Docker and you need "*" hosts
ALLOW_ALL_HOSTS_DEV=False
